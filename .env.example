# AI-Assistant 环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=ai-assistant
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# 数据库配置 (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/all_in_ai
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/all_in_ai
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# AgentScope 配置
AGENTSCOPE_MODEL_CONFIG_PATH=configs/model_config.json

# LLM 配置 (根据使用的模型选择配置)
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# 阿里云 DashScope
DASHSCOPE_API_KEY=your-dashscope-api-key

# 其他配置
REDIS_URL=redis://localhost:6379/0
